{
  "expo": {
    "name": "CommuTech",
    "slug": "commutech",
    "scheme": "commutech",
    "owner": "mhmd1441",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/commutech_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/commutech_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "CommuTech uses the camera to capture report photos and worker resolution proof.",
        "NSPhotoLibraryUsageDescription": "CommuTech uses your photo library so you can update your profile picture.",
        "NSLocationWhenInUseUsageDescription": "CommuTech uses your location to place reports accurately and show nearby issues."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/commutech_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./src/assets/commutech_logo.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "ba66a7dc-b12f-46c3-899a-7d41ec707b48"
      }
    }
  }
}
